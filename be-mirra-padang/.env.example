# ============================================================
# MIRRA PADANG - Environment Configuration
# Copy file ini menjadi .env lalu sesuaikan nilainya:
#   cp .env.example .env
#
# JANGAN PERNAH commit file .env (sudah ada di .gitignore)
# ============================================================

# --- Database (TimescaleDB / PostgreSQL) ---
DB_HOST=127.0.0.1
DB_PORT=5434
DB_NAME=djka_monitoring
DB_USER=djka_admin
DB_PASSWORD=ganti_dengan_password_kuat

# --- Redis (Celery broker/backend) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6378

# --- MQTT Broker (Mosquitto) ---
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=ganti_username_mqtt
MQTT_PASSWORD=ganti_password_mqtt

# --- API ---
API_PORT=8888
